# ─────────────────────────────────────────────────────────────────────────────
# website-backend — environment variables
#
# Copy to `.env` and fill in. NEVER commit a real .env. Values shown after `=`
# are DEFAULTS baked into the code (omit the var to accept them); [required]
# means the app won't work correctly without it. Secrets shown as CHANGE_ME.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster/jointprinting   # [required] the db name in the URI is where GridFS images live too
PORT=8080
NODE_ENV=production
JWT_SECRET=CHANGE_ME                       # [required] signs Studio session tokens
ALLOWED_ORIGINS=https://jointprinting.com,https://www.jointprinting.com  # CORS allow-list (comma-separated)
BACKEND_URL=https://api.jointprinting.com  # this API's own public base (used in generated links)
SITE_BASE_URL=https://jointprinting.com    # the public marketing site's base
CSP_ENABLED=                               # set to any value to send a Content-Security-Policy header
LIMIT=                                      # optional express json/body size limit override

# ── Studio admin auth ────────────────────────────────────────────────────────
STUDIO_NEW_PASSWORD=CHANGE_ME              # [required] the Studio (/studio) login password
STUDIO_TOKEN_TTL=7d                        # Studio JWT lifetime (e.g. 1d, 7d, 12h)
# Optional HTTP Basic gate in front of everything (staging lock):
AB_USER=
AB_PASSWORD=
AB_BASIC_AUTH_USER=
AB_BASIC_AUTH_PASSWORD=

# ── Transactional email / SMTP (approvals, notifications) ────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=CHANGE_ME
EMAIL_FROM=orders@jointprinting.com
EMAIL_TO=owner@jointprinting.com
APPROVAL_NOTIFY_EMAIL=owner@jointprinting.com

# ── Cold-outreach engine (mail merge) ────────────────────────────────────────
OUTREACH_EMAIL_FROM=hello@jointprintingshop.com   # the sending address (own the domain + DNS auth)
OUTREACH_SENDER_NAME=Joint Printing
OUTREACH_SENDERS=                          # optional pool of extra from-addresses (comma-separated) to spread volume
OUTREACH_REPLY_TO=
OUTREACH_UNSUB_MAILTO=unsubscribe@jointprintingshop.com
OUTREACH_POSTAL_ADDRESS=                   # CAN-SPAM footer postal address
OUTREACH_PUBLIC_API_BASE=                  # public base for open-pixel / unsubscribe links
OUTREACH_DAILY_CAP=50                      # max sends per day (whole engine)
OUTREACH_DOMAIN_DAILY_CAP=15               # max sends per recipient domain per day
OUTREACH_BATCH_PER_TICK=5                  # sends per cron tick
OUTREACH_LEASE_MS=                         # per-recipient send lease (atomic claim) window
OUTREACH_MAX_BOUNCE_RATE=                  # circuit-breaker: pause if bounce rate exceeds this
OUTREACH_MAX_COMPLAINT_RATE=               # circuit-breaker: pause if complaint rate exceeds this
OUTREACH_BREAKER_MIN_SAMPLE=               # min sample size before the breaker can trip
OUTREACH_DKIM_SELECTOR=                    # DKIM selector to check (SendPulse uses `sign`)
OUTREACH_DMARC_GATE=                       # require DMARC before sending (on/off)
OUTREACH_AUTH_CACHE_MS=                    # DNS auth (SPF/DKIM/DMARC) result cache TTL
OUTREACH_DSTATS_TTL_MS=
OUTREACH_OPEN_PIXEL=                        # enable the open-tracking pixel (on/off)
OUTREACH_BOUNCE_SECRET=CHANGE_ME           # shared secret authenticating the bounce webhook

# ── Lead finder (free OSM dispensary discovery) ──────────────────────────────
LEAD_FINDER_LOW_WATERMARK=40               # refill when the cold-lead reserve drops below this
LEAD_FINDER_REFILL_TARGET=75               # sweep states until this many new leads are added
LEAD_FINDER_MAX_REGIONS=6                  # max states swept per refill run
LEAD_FINDER_MAX_UPGRADE=3                  # max already-swept states re-milked per run after a finder upgrade
LEAD_FINDER_MAX_ENRICH=80                  # max site-scrapes per region per run
LEAD_FINDER_CONCURRENCY=4                  # concurrent site scrapes
LEAD_FINDER_SKIP_CHAINS=                   # set to `off` to include big MSO chains
LEAD_FINDER_VERIFY_MX=                     # set to `off` to skip MX deliverability verification

# ── Google integrations ──────────────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=CHANGE_ME
GMAIL_REFRESH_TOKEN=CHANGE_ME
GMAIL_TRIAGE_ENABLED=                       # set to `true` to enable live Gmail reply ingest
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=CHANGE_ME
GDRIVE_REDIRECT_URI=
GDRIVE_KEEP=                                # Drive housekeeping toggle
GOOGLE_PLACES_KEY=                          # optional; the lead finder is $0/keyless without it
PAGESPEED_KEY=                              # optional PageSpeed Insights key (JPW audits)

# ── S&S Activewear catalog proxy ─────────────────────────────────────────────
SS_ACCOUNT=
SS_API_KEY=CHANGE_ME
SS_API_BASE=
SS_CDN_BASE=

# ── Maps ─────────────────────────────────────────────────────────────────────
MAPBOX_TOKEN=CHANGE_ME
REACT_APP_MAPBOX_TOKEN=CHANGE_ME           # mirror consumed by the frontend build

# ── AI / receipts ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=CHANGE_ME                # receipt OCR / parsing
RECEIPT_MODEL=                             # override the model id used for receipts

# ── JPW site spider / weekly audits ──────────────────────────────────────────
JPW_WEEKLY_SWEEP_ENABLED=                   # `true` to enable the weekly site sweep
JPW_WEEKLY_SWEEP_MAX=
JPW_NIGHTLY_AUDIT_CAP=
JPW_PLACES_DAILY_CAP=
JPW_STALE_AUDIT_DAYS=
JPW_SPIDER_TAB=
JPW_SPIDER_WEBHOOK_URL=
JPW_SPIDER_SHARED_SECRET=CHANGE_ME

# ── Self-identity (reply/thread matching) ────────────────────────────────────
SELF_DOMAINS=jointprinting.com,jointprintingshop.com   # our own domains (never cold-email / treat as internal)
SELF_NAMES=Joint Printing                              # our own display names

# ── Data import / maintenance (one-off scripts) ──────────────────────────────
FINANCE_BUDGET_DIR=
FINANCE_QB_DEPOSITS=
LEDGER_PATH=
NOTION_CSV=
SCRATCH_OUT=
FORMAT_START=
R2_AUTOMIGRATE=                             # set to `off` to skip the boot data migration
