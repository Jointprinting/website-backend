# ─────────────────────────────────────────────────────────────
#  Joint Printing — backend env
#  Copy this to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Mongo
MONGO_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/jointprinting

# Server
PORT=8080
# Comma-separated list of allowed origins for CORS. Leave empty to allow all
# (good for early testing; tighten in production).
ALLOWED_ORIGINS=https://jointprinting.com,https://www.jointprinting.com,http://localhost:3000

# Studio (admin) auth
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
STUDIO_TOKEN_TTL=8h

# Email — outbound SMTP (SendPulse, etc.)
SMTP_HOST=smtp-pulse.com
SMTP_PORT=2525
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
EMAIL_FROM=hello@jointprinting.com
EMAIL_TO=nate@jointprinting.com

# S&S Activewear (NEW — used by /api/products/ss/sync)
SS_ACCOUNT=your-ss-account-number
SS_API_KEY=your-ss-api-key
# Optional overrides:
# SS_API_BASE=https://api.ssactivewear.com/V2
# SS_CDN_BASE=https://cdn.ssactivewear.com/

# Alpha Broder (kept as a fallback, only needed for the manual-entry admin tab)
AB_USER=
AB_PASSWORD=
AB_BASIC_AUTH_USER=
AB_BASIC_AUTH_PASSWORD=
